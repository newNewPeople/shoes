# 服务端口
PORT=3000

# PostgreSQL（默认本地单机库，可按需修改）
DATABASE_URL=postgresql://shoes:shoes@127.0.0.1:5432/shoes

# 公网访问根地址（图片 URL 给小程序/LLM 用；生产请改为 HTTPS 域名）
PUBLIC_BASE_URL=http://127.0.0.1:3000

# ========== 火山方舟 AI（建议全部写在此文件，换人不改小程序/管理页）==========
# 控制台 → API Key 管理 → 复制 ark- 开头的 Key
SHOES_AI_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

SHOES_AI_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# LLM：预置接入点可用模型 ID，或 ep-m-xxx（在线推理 → 预置推理接入点）
SHOES_LLM_MODEL=doubao-seed-2-0-pro-260215

# Embedding：必须单独创建接入点（在线推理 → 创建在线推理 → 添加 embedding 模型）
# 创建后填入 ep-xxx，搜图/入库依赖此项
SHOES_EMBEDDING_MODEL=ep-xxxxxxxx-xxxxx

SHOES_EMBEDDING_DIMENSIONS=2048

# 可选
# SHOES_LLM_TEMPERATURE=0.1
# SHOES_AI_TIMEOUT=120000
